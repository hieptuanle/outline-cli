{
	"name": "@hieptuanle/outline-cli",
	"version": "1.5.1",
	"description": "CLI for the Outline wiki/knowledge base API",
	"type": "module",
	"bin": {
		"ol": "dist/index.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hieptuanle/outline-cli.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/hieptuanle/outline-cli#readme",
	"bugs": {
		"url": "https://github.com/hieptuanle/outline-cli/issues"
	},
	"files": [
		"dist",
		"scripts",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"type-check": "tsc --noEmit",
		"lint:check": "oxlint src",
		"lint:write": "oxlint src --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"test": "vitest run",
		"test:watch": "vitest",
		"postinstall": "node scripts/postinstall.js",
		"check:skill-sync": "node scripts/check-skill-sync.js",
		"sync:skill": "npm run build && node scripts/sync-skill.js",
		"prepublishOnly": "npm run build && npm test"
	},
	"keywords": [
		"outline",
		"wiki",
		"cli"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.18.1"
	},
	"dependencies": {
		"chalk": "5.6.2",
		"commander": "14.0.2",
		"marked": "15.0.12",
		"marked-terminal": "7.3.0",
		"open": "10.2.0",
		"undici": "7.22.0",
		"yocto-spinner": "1.0.0"
	},
	"devDependencies": {
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/git": "10.0.1",
		"@types/node": "25.0.10",
		"conventional-changelog-conventionalcommits": "9.3.0",
		"lefthook": "2.0.15",
		"oxfmt": "0.42.0",
		"oxlint": "1.57.0",
		"semantic-release": "25.0.3",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	}
}
